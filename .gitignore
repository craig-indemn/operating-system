# Credentials — never commit
*_secret.json
credentials.json
*.pem
.env
.env.*

# Local Claude Code settings (personal permissions)
.claude/settings.local.json

# Session state files (runtime, updated by hooks on every event)
/sessions/

# Python bytecode
__pycache__/

# Node — package manager downloads, reproducible from package.json
node_modules/

# macOS Finder metadata
.DS_Store

# Logs
.logs/

# Hive synced cache (rebuilt via hive sync)
hive/.synced/
